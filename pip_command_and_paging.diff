+static int SelectTLBVictim() {
+    // Prefer an invalid slot first
+    for (int i = 0; i < TLBSize; i++) {
+        if (!kernel->machine->tlb[i].valid) {
+            return i;
+        }
+    }
+    // Round-robin replacement
+    int victim = nextTLBSlot;
+    nextTLBSlot = (nextTLBSlot + 1) % TLBSize;
+    return victim;
